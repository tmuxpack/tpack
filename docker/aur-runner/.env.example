# GitHub repo the runner attaches to.
REPO_URL=https://github.com/tmuxpack/tpack

# Fine-grained PAT with "Administration: Read & Write" on tmuxpack/tpack.
# Used only at container start to mint a short-lived runner registration token.
GITHUB_PAT=ghp_replace_me

# Absolute path on the host to the AUR SSH private key.
# Mode 600. Bind-mounted read-only into /home/runner/.ssh/aur.
AUR_SSH_KEY_PATH=/absolute/path/to/aur_ed25519

# Runner display name in GitHub Settings > Actions > Runners.
RUNNER_NAME=tpack-aur-publisher

# Labels applied at registration. The workflow targets "aur-publisher".
RUNNER_LABELS=aur-publisher
